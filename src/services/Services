import {
  collection,
  doc,
  addDoc,
  setDoc,
  updateDoc,
  deleteDoc,
  getDoc,
  getDocs,
  query,
  onSnapshot,
  where,
  orderBy,
} from "firebase/firestore";

import { db } from "../config/firebase-config";

export async function AddDoc(path, data) {
  return await addDoc(collection(db, ...path), data);
}

export async function SetDoc(path, data) {
  return await setDoc(doc(db, ...path), data);
}

export async function UpdateDoc(path, data) {
  return await updateDoc(doc(db, ...path), data);
}

export async function GetDocument(path, data) {
  const snapshot = await getDoc(doc(db, ...path));
  if (!snapshot.exists()) return null;
  return {
    id: snapshot.id,
    ...snapshot.data(),
  };
}
export async function deleteDocument(path) {
  return await deleteDoc(doc(db, ...path));
}

export async function GetCollection(path, data) {
  const snapshot = await getDocs(collection(db, ...path));

  return snapshot.docs.map((doc) => ({
    id: doc.id,
    ...doc.data(),
  }));
}

export function subscribeToCollection(path, onSuccess, onError) {
  const q = query(collection(db, ...path), orderBy("createdAt", "asc"));
  const unsubscribe = onSnapshot(
    q,
    //snapshot this is a success callback
    (snapshot) => {
      const data = snapshot.docs.map((doc) => ({
        id: doc.id,
        ...doc.data(),
      }));
      onSuccess(data);
    },
    (error) => {
      onError(error);
    },
  );

  return unsubscribe;
}
export function subscribeToChats(uid, onSuccess, onError) {
  const q = query(
    collection(db, "Chat"),
    where("members", "array-contains", uid),
    orderBy("updatedAt", "desc"),
  );

  return onSnapshot(
    q,

    (snapshot) => {
      const chats = snapshot.docs.map((doc) => ({
        id: doc.id,
        ...doc.data(),
      }));

      onSuccess(chats);
    },

    (error) => {
      onError(error);
    },
  );
}
